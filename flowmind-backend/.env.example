# ─────────────────────────────────────────────────────────────────
# FlowMind AI — Environment Variable Reference
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development            # development | production | test
PORT=4000                       # HTTP port the API server listens on

# ── Database ─────────────────────────────────────────────────────
# Docker-internal URL uses service name "postgres" as host.
# For direct host access: postgresql://user:pass@localhost:5432/flowmind
DATABASE_URL="postgresql://USER:PASSWORD@postgres:5432/flowmind?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-db-password
POSTGRES_DB=flowmind

# ── Redis ────────────────────────────────────────────────────────
REDIS_HOST=redis                # Docker service name; use "localhost" outside Docker
REDIS_PORT=6379

# ── Auth ─────────────────────────────────────────────────────────
# Generate a secure secret: openssl rand -base64 64
JWT_SECRET=your-super-secure-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d               # e.g. 1h, 7d, 30d

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
